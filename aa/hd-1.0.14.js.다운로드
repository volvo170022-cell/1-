// ----------------------------------------------------------
// 휠 점프
// ----------------------------------------------------------
// hd-wheel 의 섹션수량 체크
$(function(){
	const hd_sections = document.querySelectorAll('.hd-wheel');

	var hd_currentSectionIndex = 0; //현재 섹션 index
	var hd_nextSectionIndex = 0; //다음 섹션 index

	// 섹션별 index 업데이트
	function hd_updateCurrentSectionIndex() {
		

		hd_sections.forEach((section, index) => {
		  const rect = section.getBoundingClientRect();		  
		  if (rect.top <= window.innerHeight && rect.bottom >= window.innerHeight) {
			hd_currentSectionIndex = index;
		  }
		});
	}

	function hd_handleWheel(event) {
		  hd_updateCurrentSectionIndex();
		  //console.log('Current Section Index0:', hd_currentSectionIndex);

		  // 휠을 내릴때..
		  if(event.deltaY > 0) {

				if(hd_nextSectionIndex != hd_currentSectionIndex){
					var goPosition = $(".hd-wheel").eq(hd_currentSectionIndex).offset();
					$('html,body').animate( { scrollTop:goPosition.top },'1000' );
					hd_nextSectionIndex = hd_currentSectionIndex;
					//console.log('Current Section Index1:', hd_currentSectionIndex);
				}

		  
		  // 휠을 올릴때..
		  } else if (event.deltaY < 0) {

				if(hd_currentSectionIndex-1 > -1){
					if(hd_nextSectionIndex != hd_currentSectionIndex-1){
						var goPosition = $(".hd-wheel").eq(hd_currentSectionIndex-1).offset();
						$('html,body').animate( { scrollTop:goPosition.top },'1000' );
						hd_nextSectionIndex = hd_currentSectionIndex-1;
						//console.log('Current Section Index2:', hd_currentSectionIndex-1);
					}
				}
		  }

		  $('.hd-wheel').removeClass("active"); //클래스주기
		  $('.hd-wheel').eq(hd_nextSectionIndex).addClass("active"); //클래스주기

		  window.removeEventListener('wheel', hd_handleWheel); // 이벤트 리스너 제거
		  setTimeout(function(){
			window.addEventListener('wheel', hd_handleWheel);
		  },10);
	  
	}
	window.addEventListener('wheel', hd_handleWheel);
})


