function hd_youtube_popup(obj,type){
	if(type == "shorts"){
		$("#hd_popup_new").addClass("shorts");
	}else{
		$("#hd_popup_new").addClass("youtube");
	}

	if(obj == "hd_popup_new"){
		onoff_obj('hd_black','','','fade','block');
	}

	$("#hd_popup_new").find("iframe").attr("src",""); //초기화	
	$("#"+obj).show();
}

