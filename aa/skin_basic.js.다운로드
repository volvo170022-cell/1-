	var spchk2 = 0;
	var spchk3 = 0;

	//숫자확인
	if(/[0-9]/.test(str)){
		spchk1 = 1;
	}

	//문자확인
	if(/[a-z]/i.test(str)){
		spchk2 = 1;
	}

	//특수문자확인
	var sp_text = "~,!,@,#,$,%,^,&,*,(,),<,>,?,.";
	var sp_arr = sp_text.split("\,");
	
	for(var i=0;i<str.length;i++){
		str_i = str.substr(i,1);
		var sp_ret = jQuery.inArray(str_i, sp_arr); //없으면 -1
		if(sp_ret > -1){
			spchk3++;
		}
	}

	if(spchk1=="1" && spchk2=="1" && str.length >= 8 && str.length <= 20){
		$(".text_length_show").eq(index_).html("<font style='color:red'> "+str.length+"글자 (적합)</font>");
