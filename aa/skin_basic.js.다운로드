// 아이디체크
function id_dchk(f){
	//한글,특수문자 차단
	var idchk = f.m_id.value.replace( /[ㄱ-ㅎ|ㅏ-ㅣ|가-힣]/g, '' ); //한글차단
	var idchk = idchk.replace( /\~|\!|\@|\#|\$|\%|\^|\&|\*|\(|\)|\?/g, '' ); //특수문자차단
	f.m_id.value = idchk;

	$.ajax({
		   type: "POST",
		   url: "./m_member_ok.php",    
		   data: "ps_mode=id_dchk&chk_id="+f.m_id.value,
		   success: function(req){
				
				req = req.replace(/(^\s*)|(\s*$)/gi, ""); //trim

				f.id_check.value = "";

				
				if(req == "not_shot"){
					var msg = "아이디는 6자리 이상 입력해주세요.";
				}else if(req == "not_long"){
					var msg = "아이디는 20자리 이하로 입력해주세요.";
				}else if(req == "ok"){
					var msg = "<div style='color:red'>사용이 가능한 아이디 입니다.</div>";
					f.id_check.value = "ok";
				}else{
					var msg = "이미 존재하는 아이디입니다.";
				}

				$("#id_chk_msg").hide().html(msg).fadeIn(100);
		   }});
}

function check_member_form() {
		var m=document.morning;
		$("#bbs_background").show();
		
		if ("undefined" == typeof m.naver_id && "undefined" == typeof m.daum_id && "undefined" == typeof m.facebook_id && "undefined" == typeof m.google_id){
			//--------------- 비밀번호패턴 --------------
			var str = m.pass1.value;
			var spchk1 = 0;
			var spchk2 = 0;
			var spchk3 = 0;

			//숫자확인
			if(/[0-9]/.test(str)){
				spchk1 = 1;
			}

			//문자확인
			if(/[a-z]/i.test(str)){
				spchk2 = 1;
			}


			//특수문자확인
			var sp_text = "~§!§@§#§$§%§^§&§*§(§)§<§>§?§.§,";
			var sp_arr = sp_text.split("\§");
			
			for(var i=0;i<str.length;i++){
				str_i = str.substr(i,1);
				var sp_ret = jQuery.inArray(str_i, sp_arr); //없으면 -1
				if(sp_ret > -1){
					spchk3++;
				}
			}
			//---------------// 비밀번호패턴 --------------


			//신규 가입일때..
			if("undefined" == typeof m.old_pass){
				if (str.length < 8 || (str.length > 20) || spchk1 < 1 || spchk2 < 1) {
				   alert("[비밀번호]는 8글자 이상, 20글자 이하의 영문,숫자 혼합으로 입력해주세요.");
				   bbs_background_close();
				   m.pass1.focus();
				   return false;
				}
			
			//비밀번호 변경일때..
			}else{
				if(str.length > 0){
					if (str.length < 8 || (str.length > 20) || spchk1 < 1 || spchk2 < 1) {
					   alert("[비밀번호]는 8글자 이상, 20글자 이하의 영문,숫자 혼합으로 입력해주세요.");
					   bbs_background_close();
					   m.pass1.focus();
					   return false;
					}
				}
			}

			if (m.pass1.value && m.pass1.value != m.pass2.value) {
				alert("비밀번호 같지 않습니다 정확히 입력해 주세요. ");
				bbs_background_close();
				m.pass1.value = "";
				m.pass2.value = "";
				$(".text_length_show").text("");
				m.pass1.focus();
				return false;
			}
		}

		//class 로 필수값 입력확인
		var ess_obj = "";
		for(var i=0;i<$(".essential").length;i++){
			ess_obj = $(".essential").eq(i);

			if(!ess_obj.val() && ess_obj.attr("essential")){
				alert(ess_obj.attr("essential"));
				bbs_background_close();
				ess_obj.focus();
				return false;
			}
		}



		if ("undefined" != typeof m.email_confirm_number){
			if (m.email_confirm.value == "22222_") {
			   alert("이메일 인증하기를 클릭하여 이메일인증을 해주세요.");
