	var originalWidth = videoFrame.attr('width');
	var originalHeight = videoFrame.attr('height');


	// 초기 이미지 크기 저장
	bodyImages.each(function () {
		originalSizes.push({
			width: $(this).css('width'),
			height: $(this).css('height')
		});
	});

	function adjustBodyImages() {
		var windowWidth = $(window).width();

		bodyImages.each(function (index) {
			
			// 창의 크기가 800px 이하일 때
			if (windowWidth <= 800) {
				
				//이미지
				$(this).css({
					'width': '100%',
					'height': 'auto'
				});
			
			// 창의 크기가 800px 이상일 때
			} else {

				//이미지
				$(this).css({
					'width': originalSizes[index].width,
					'height': originalSizes[index].height
				});
			}
		});


		// 창의 크기가 800px 이하일 때
		if (windowWidth <= 800) {
			//유투브
			videoFrame.css({
				'width': '100%',
				'height': (windowWidth / originalWidth) * originalHeight
			});
		
		// 창의 크기가 800px 이상일 때
		} else {

			//유투브
			videoFrame.css({
				'width': originalWidth,
				'height': originalHeight
			});
		}

	}


	// 페이지 로드 시와 창 크기 변경 시에도 체크
	$(window).on('load resize', adjustBodyImages);
});


