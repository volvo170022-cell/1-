// 가격 3자리 점찍기
// ----------------------------------------------------------
function money_format(n){
	var str = (n<0)? "-": "";
	var s = (n<0)? -n+"": n+"";
	var len = s.length;
	for(var i=0; i<len; i++){
		str += s.charAt(i);
		var j = len-i;
		if(j>1 && j%3==1)
			str +=",";
	}
	return str;
}


