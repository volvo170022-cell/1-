function addCommas(strValue){ 
	var objRegExp = new RegExp('(-?[0-9]+)([0-9]{3})'); 

	while(objRegExp.test(strValue)) { 
	strValue = strValue.replace(objRegExp, '$1,$2'); 
	} 
	return strValue; 
}


