            cnt_num++;
          }
        }
        stock_check = 1;
      }
      gift_price  = gift_price + (eval(temparray2[6])*eval(gift_num[i]));	
    }
    cnt_num = 0;
  }

  if(!gift_price){
    gift_price = 0;
  }

  if(eval(total_price) < eval(gift_price)){
